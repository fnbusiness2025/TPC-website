{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/(client)"
		},
		{
			"src": "^/about/?(?:/__data.json)?$",
			"dest": "/(client)/about"
		},
		{
			"src": "^/admin/?(?:/__data.json)?$",
			"dest": "/(admin)/admin"
		},
		{
			"src": "^/admin/admins/?(?:/__data.json)?$",
			"dest": "/(admin)/admin/admins"
		},
		{
			"src": "^/admin/admins/new/?(?:/__data.json)?$",
			"dest": "/(admin)/admin/admins/new"
		},
		{
			"src": "^/admin/agents/?(?:/__data.json)?$",
			"dest": "/(admin)/admin/agents"
		},
		{
			"src": "^/admin/agents/pending/?(?:/__data.json)?$",
			"dest": "/(admin)/admin/agents/pending"
		},
		{
			"src": "^/agent/?(?:/__data.json)?$",
			"dest": "/(client)/agent"
		},
		{
			"src": "^/agent/new/?(?:/__data.json)?$",
			"dest": "/(client)/agent/new"
		},
		{
			"src": "^/agent/properties/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/(client)/agent/properties/[id]"
		},
		{
			"src": "^/contact/?(?:/__data.json)?$",
			"dest": "/(client)/contact"
		},
		{
			"src": "^/login/?(?:/__data.json)?$",
			"dest": "/(client)/login"
		},
		{
			"src": "^/properties/?(?:/__data.json)?$",
			"dest": "/(client)/properties"
		},
		{
			"src": "^/properties/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/(client)/properties/[id]"
		},
		{
			"src": "^/services/?(?:/__data.json)?$",
			"dest": "/(client)/services"
		},
		{
			"src": "^/services/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/(client)/services/[slug]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}